      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('conversations success', () => pm.expect(json.status).to.eql(1));",
              "const content = json.payload && json.payload.content ? json.payload.content : [];",
              "if (content.length > 0) {",
              "  pm.collectionVariables.set('conversationId', content[0].id);",
              "  pm.collectionVariables.set('psid', content[0].senderPsid);",
              "  console.log('Saved conversationId:', content[0].id);",
              "  console.log('Saved psid:', content[0].senderPsid);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
