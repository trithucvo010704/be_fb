            "{{pageId}}"
          ]
        }
      }
    },
    {
      "name": "05 Webhook Verify",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/base/facebook/webhooks?hub.mode=subscribe&hub.verify_token={{verifyToken}}&hub.challenge=123456",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "base",
            "facebook",
            "webhooks"
          ],
          "query": [
            {
              "key": "hub.mode",
              "value": "subscribe"
            },
            {
              "key": "hub.verify_token",
              "value": "{{verifyToken}}"
            },
            {
              "key": "hub.challenge",
              "value": "123456"
            }
          ]
        }
      }
    },
    {
