{
  "info": {
    "name": "Facebook Service - Ngrok App Review Test",
    "_postman_id": "2f14c717-2ba8-4691-9a57-facebook-service",
    "description": "Postman collection test local/ngrok flow: demo login, OAuth, pages, inbox, send message, publish post, data deletion, disconnect.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
