      "value": ""
    },
    {
      "key": "verifyToken",
      "value": "PFIVShXYCLAwNYtV"
    }
  ],
  "item": [
    {
      "name": "01 Demo Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/demo-login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "demo-login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('login success', () => pm.expect(json.status).to.eql(1));",
              "const token = json.payload && (json.payload.token || json.payload.accessToken);",
              "pm.expect(token, 'token').to.be.ok;",
              "pm.collectionVariables.set('token', token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 Get OAuth URL",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/facebook/oauth/url",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "facebook",
            "oauth",
            "url"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('oauth url success', () => pm.expect(json.status).to.eql(1));",
              "pm.test('oauth url exists', () => pm.expect(json.payload.url).to.include('facebook.com'));",
              "console.log('Open this URL in browser:', json.payload.url);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 List Connected Pages",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/pages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "pages"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('pages success', () => pm.expect(json.status).to.eql(1));",
              "const pages = Array.isArray(json.payload) ? json.payload : (json.payload && json.payload.content) || [];",
              "if (pages.length > 0) {",
              "  pm.collectionVariables.set('pageId', pages[0].fbPageId || pages[0].id);",
              "  console.log('Saved pageId:', pm.collectionVariables.get('pageId'));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
